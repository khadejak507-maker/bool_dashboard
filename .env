# Base URL of the FastAPI backend (no trailing slash, no /api/v1 prefix).
# Local default is http://localhost:8000
VITE_API_URL=https://frosted-griminess-obvious.ngrok-free.dev

# Google OAuth Web client ID — used to let users sign in and pick a private
# Google Spreadsheet. Must match the backend GOOGLE_CLIENT_ID and have this
# app's origin (e.g. http://localhost:3000) under "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=445952654556-gbutdphc7uv4p84tqt9v0h2fjc1ebk0c.apps.googleusercontent.com
